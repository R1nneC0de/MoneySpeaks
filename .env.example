# MoneySpeaks Environment Variables
# Copy to backend/.env and fill in values
# App runs in mock mode when keys are missing

# ElevenLabs - TTS warnings + training data generation
ELEVENLABS_API_KEY=

# Google Gemini - affective analysis via Gemini Live
GEMINI_API_KEY=

# Auth0 - user profiles + trusted contact flows
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=

# DigitalOcean - deployed wav2vec2 inference endpoint
DIGITALOCEAN_INFERENCE_URL=

# Anthropic - fallback for scam intent classification
ANTHROPIC_API_KEY=
